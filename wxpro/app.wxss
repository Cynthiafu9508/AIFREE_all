/* 全局样式 */
page {
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  background-color: #ffffff;
  color: #333333;
  font-size: 28rpx;
  box-sizing: border-box;
  height: 100%;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

