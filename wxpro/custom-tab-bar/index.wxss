.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: row;
  align-items: center;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.tab-icon {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 4rpx;
}

.tab-label {
  font-size: 20rpx;
  color: #999999;
  line-height: 1;
}

.tab-label.active {
  color: #18AEFB;
}
