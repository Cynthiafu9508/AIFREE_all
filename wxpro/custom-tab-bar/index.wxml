<view class="tab-bar">
  <view
    class="tab-item"
    wx:for="{{tabs}}"
    wx:key="pagePath"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <image
      class="tab-icon"
      src="{{selected === index ? item.activeIcon : item.icon}}"
      mode="aspectFit"
    />
    <text class="tab-label {{selected === index ? 'active' : ''}}">{{item.text}}</text>
  </view>
</view>
