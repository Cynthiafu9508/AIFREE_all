.page {
  min-height: 100vh;
  padding: 120rpx 60rpx 60rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
}

.header {
  margin-bottom: 72rpx;
}
.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
}
.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.input-wrap {
  position: relative;
  margin-bottom: 32rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  background: #F5F6F8;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #333;
}

.placeholder {
  color: #BBBBBB;
  font-size: 30rpx;
}

.eye-btn {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  color: #999;
}

.phone-wrap {
  display: flex;
  align-items: center;
  height: 96rpx;
  background: #F5F6F8;
  border-radius: 16rpx;
  overflow: hidden;
}
.phone-prefix {
  padding: 0 24rpx 0 32rpx;
  font-size: 30rpx;
  color: #333;
  white-space: nowrap;
  flex-shrink: 0;
}
.divider-v {
  width: 2rpx;
  height: 40rpx;
  background: #DDDDDD;
  flex-shrink: 0;
}
.phone-input {
  flex: 1;
  background: transparent;
  border-radius: 0;
  padding-left: 24rpx;
}

.code-wrap {
  display: flex;
  align-items: center;
  height: 96rpx;
  background: #F5F6F8;
  border-radius: 16rpx;
  overflow: hidden;
}
.code-input {
  flex: 1;
  background: transparent;
  border-radius: 0;
}
.code-btn {
  padding: 0 28rpx;
  font-size: 26rpx;
  color: #29A8E0;
  white-space: nowrap;
  flex-shrink: 0;
  border-left: 2rpx solid #DDDDDD;
  height: 96rpx;
  line-height: 96rpx;
}
.code-btn-disabled {
  color: #BBBBBB;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: #29A8E0;
  border-radius: 48rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary::after { border: none; }

.back-row {
  display: flex;
  justify-content: center;
  margin-top: 36rpx;
}
.back-link {
  font-size: 28rpx;
  color: #666;
}

.field-toast {
  position: absolute;
  top: -64rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(40, 40, 40, 0.88);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  white-space: nowrap;
  z-index: 10;
  pointer-events: none;
}
