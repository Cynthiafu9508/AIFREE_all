<view class="page">

  <!-- 头像区 -->
  <view class="avatar-wrap" bindtap="switchAvatar">
    <view class="avatar-circle">
      <image class="avatar-img" src="{{avatar}}" mode="aspectFit" />
    </view>
    <!-- 换一换提示角标 -->
    <view class="avatar-badge">
      <text class="avatar-badge-icon">🎲</text>
    </view>
  </view>

  <!-- 昵称卡片 -->
  <view class="card">
    <view class="menu-row" bindtap="editNickname">
      <text class="menu-label">昵称</text>
      <view class="menu-right">
        <text class="menu-value">{{nickname}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单卡片 -->
  <view class="card">
    <view class="menu-row" bindtap="goPasswordSetting">
      <text class="menu-label">密码设置</text>
      <text class="arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="menu-row" bindtap="goDeviceManage">
      <text class="menu-label">设备管理</text>
      <text class="arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="menu-row" bindtap="goHelp">
      <text class="menu-label">帮助与客服</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 退出登录卡片 -->
  <view class="card logout-card" bindtap="onLogout">
    <text class="logout-text">退出登录</text>
  </view>

  <view class="tab-placeholder"></view>

  <!-- 昵称编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showNicknameModal}}" bindtap="cancelNickname">
    <view class="modal-card" catchtap="">
      <text class="modal-title">昵称</text>
      <input class="modal-input" placeholder="请输入昵称" placeholder-class="modal-placeholder"
        value="{{nicknameInput}}" bindinput="onNicknameInput" maxlength="20" focus="{{showNicknameModal}}" />
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="cancelNickname">取消</view>
        <view class="modal-btn confirm" bindtap="confirmNickname">确 认</view>
      </view>
    </view>
  </view>

</view>
