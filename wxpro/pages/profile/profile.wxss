/* ========================
   我的页  profile.wxss
   ======================== */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #daeef8 0%, #c4e2f0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 10vh);
  padding-bottom: 0;
}

/* ── 头像区 ── */
.avatar-wrap {
  display: flex;
  justify-content: center;
  padding: 64rpx 0 48rpx;
}

.avatar-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #18AEFB;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(24, 174, 251, 0.3);
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
}

/* ── 通用卡片 ── */
.card {
  width: calc(100% - 64rpx);
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

/* ── 菜单行 ── */
.menu-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx;
}

.menu-label {
  font-size: 32rpx;
  color: #222222;
  font-weight: 400;
}

.menu-right {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.menu-value {
  font-size: 30rpx;
  color: #999999;
  margin-right: 8rpx;
}

.arrow {
  font-size: 40rpx;
  color: #cccccc;
  line-height: 1;
  margin-top: -4rpx;
}

/* ── 分割线 ── */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 32rpx;
}

/* ── 退出登录 ── */
.logout-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.logout-text {
  font-size: 32rpx;
  color: #aaaaaa;
}

/* ── TabBar 占位 ── */
.tab-placeholder {
  height: calc(100rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
