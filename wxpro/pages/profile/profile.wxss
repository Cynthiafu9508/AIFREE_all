.page { min-height: 100vh; background: #f5f5f5; display: flex; flex-direction: column; align-items: center; }
.placeholder { flex: 1; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #999; }
.tab-placeholder { height: calc(100rpx + env(safe-area-inset-bottom)); }
