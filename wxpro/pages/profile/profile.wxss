/* ========================
   我的页  profile.wxss
   ======================== */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #daeef8 0%, #c4e2f0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 10vh);
  padding-bottom: 0;
}

/* ── 头像区 ── */
.avatar-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  padding: 64rpx 0 48rpx;
}

.avatar-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #18AEFB;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(24, 174, 251, 0.3);
}

/* 图片缩小留出内边距，不裁切 */
.avatar-img {
  width: 120rpx;
  height: 120rpx;
}

/* 右下角角标：提示可点击换头像 */
.avatar-badge {
  position: absolute;
  bottom: 44rpx;
  right: -8rpx;
  width: 48rpx;
  height: 48rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.avatar-badge-icon {
  font-size: 28rpx;
  line-height: 1;
}

/* ── 通用卡片 ── */
.card {
  width: calc(100% - 64rpx);
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

/* ── 菜单行 ── */
.menu-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx;
}

.menu-label {
  font-size: 32rpx;
  color: #222222;
  font-weight: 400;
}

.menu-right {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.menu-value {
  font-size: 30rpx;
  color: #999999;
  margin-right: 8rpx;
}

.arrow {
  font-size: 40rpx;
  color: #cccccc;
  line-height: 1;
  margin-top: -4rpx;
}

/* ── 分割线 ── */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 32rpx;
}

/* ── 退出登录 ── */
.logout-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.logout-text {
  font-size: 32rpx;
  color: #aaaaaa;
}

/* ── 昵称弹窗 ── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-card {
  width: 560rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #222;
  margin-bottom: 32rpx;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 44rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.modal-placeholder {
  color: #bbbbbb;
}

.modal-btns {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #f0f0f0;
  color: #666;
}

.modal-btn.confirm {
  background: #18AEFB;
  color: #ffffff;
  letter-spacing: 4rpx;
}

/* ── TabBar 占位 ── */
.tab-placeholder {
  height: calc(100rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
