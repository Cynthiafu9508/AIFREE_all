<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">‹</view>
    <text class="nav-title">设备管理</text>
    <view class="nav-right"></view>
  </view>

  <scroll-view class="content" scroll-y>

    <!-- 设备头像 + 名称 -->
    <view class="avatar-section">
      <view class="avatar-circle">
        <image class="avatar-img" src="/images/partner.png" mode="aspectFill" />
      </view>
      <text class="device-name">{{deviceName || '未绑定设备'}}</text>
    </view>

    <!-- 卡片1：切换 / 添加 -->
    <view class="card">
      <view class="row" bindtap="onSwapDevice">
        <text class="row-label">切换选中设备</text>
        <view class="row-right">
          <text class="row-hint">点击切换</text>
          <text class="row-icon-swap">⇄</text>
        </view>
      </view>
      <view class="divider"></view>
      <view class="row" bindtap="onAddDevice">
        <text class="row-label">添加新设备</text>
        <text class="row-arrow">›</text>
      </view>
    </view>

    <!-- 卡片2：玩偶昵称 / 固件版本 / 设备状态 -->
    <view class="card">
      <view class="row" bindtap="onEditNickname">
        <text class="row-label">玩偶昵称</text>
        <view class="row-right">
          <text class="row-value">{{deviceName || '未设置'}}</text>
          <text class="row-arrow">›</text>
        </view>
      </view>
      <view class="divider"></view>
      <view class="row">
        <text class="row-label">固件版本</text>
        <text class="row-value">{{firmware || '1.9.0'}}</text>
      </view>
      <view class="divider"></view>
      <view class="row">
        <text class="row-label">设备状态</text>
        <view class="status-badge">
          <view class="status-dot {{online ? 'online' : 'offline'}}"></view>
          <text class="status-text">{{online ? '在线' : '离线'}}</text>
        </view>
      </view>
    </view>

    <!-- 卡片3：重新配网 -->
    <view class="card">
      <view class="row" bindtap="onConfigNetwork">
        <text class="row-label">设备重新配网</text>
        <text class="row-arrow">›</text>
      </view>
    </view>

    <!-- 卡片4：解绑 -->
    <view class="card card-unbind" bindtap="onUnbind">
      <text class="unbind-text">设备解绑</text>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <!-- 昵称编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showNicknameModal}}" bindtap="cancelNickname">
    <view class="modal-card" catchtap="">
      <text class="modal-title">玩偶昵称</text>
      <input class="modal-input" placeholder="请输入昵称" placeholder-class="modal-placeholder"
        value="{{nicknameInput}}" bindinput="onNicknameInput" maxlength="20" focus="{{showNicknameModal}}" />
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="cancelNickname">取消</view>
        <view class="modal-btn confirm" bindtap="confirmNickname">确 认</view>
      </view>
    </view>
  </view>
</view>
