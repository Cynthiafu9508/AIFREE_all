.page {
  min-height: 100vh;
  background: #eef0f5;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  height: 88rpx;
  background: #eef0f5;
}

.nav-back {
  font-size: 56rpx;
  color: #333;
  width: 64rpx;
  line-height: 1;
  margin-top: -8rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
}

.nav-right { width: 64rpx; }

.content {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 32rpx 0;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 48rpx;
}

.avatar-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  padding: 0 0 16rpx;
}

.avatar-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #18AEFB;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(24, 174, 251, 0.3);
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
}

.avatar-badge {
  position: absolute;
  bottom: 12rpx;
  right: -8rpx;
  width: 48rpx;
  height: 48rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.avatar-badge-icon {
  font-size: 28rpx;
  line-height: 1;
}

.device-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #111;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 108rpx;
}

.row-label {
  font-size: 30rpx;
  color: #111;
}

.row-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.row-hint {
  font-size: 28rpx;
  color: #aaa;
}

.row-icon-swap {
  font-size: 32rpx;
  color: #18AEFB;
}

.row-value {
  font-size: 28rpx;
  color: #aaa;
}

.row-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-right: -8rpx;
}

.divider {
  height: 1rpx;
  background: #f2f2f2;
}

/* 设备状态角标 */
.status-badge {
  display: flex;
  align-items: center;
  background: #f0f0f0;
  border-radius: 32rpx;
  padding: 8rpx 20rpx;
  gap: 8rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.status-dot.online { background: #52c41a; }
.status-dot.offline { background: #aaa; }

.status-text {
  font-size: 26rpx;
  color: #666;
}

/* 解绑卡片 */
.card-unbind {
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 108rpx;
}

.unbind-text {
  font-size: 32rpx;
  color: #FF4D4F;
  font-weight: 500;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-card {
  width: 560rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 36rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
  display: block;
  margin-bottom: 32rpx;
  text-align: center;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 44rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 40rpx;
}

.modal-placeholder { color: #bbb; }

.modal-btns {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #18AEFB;
  color: #ffffff;
}

.bottom-space { height: 80rpx; }

/* 解绑确认弹窗 */
.unbind-modal {
  width: 560rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 56rpx 48rpx 40rpx;
}

.unbind-modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
  text-align: center;
  margin-bottom: 28rpx;
}

.unbind-modal-content {
  display: block;
  font-size: 28rpx;
  color: #444;
  line-height: 1.75;
  text-align: center;
  margin-bottom: 48rpx;
}

.unbind-modal-btns {
  display: flex;
  gap: 24rpx;
}

.unbind-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.unbind-btn.cancel {
  background: #f0f0f0;
  color: #333;
}

.unbind-btn.confirm {
  background: #18AEFB;
  color: #ffffff;
}

/* 添加设备引导弹窗 */
.add-modal {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 48rpx 40rpx;
}

.add-modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 32rpx;
}

.add-modal-step {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.add-modal-img {
  width: 100%;
  margin: 16rpx 0 24rpx;
  border-radius: 16rpx;
}

.add-modal-btn {
  width: 100%;
  height: 96rpx;
  background: #18AEFB;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  margin-top: 8rpx;
}

/* 切换设备底部面板 */
.sheet-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 998;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.sheet {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 24rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
}

.sheet-close {
  font-size: 36rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sheet-list {
  flex: 1;
  padding: 0 24rpx 24rpx;
}

.sheet-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  box-sizing: border-box;
  width: 100%;
  border-radius: 20rpx;
  margin-bottom: 8rpx;
}

.sheet-item.active {
  background: #edf6ff;
}

.sheet-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(160deg, #7dd8f8 0%, #29b6f6 100%);
  flex-shrink: 0;
}

.sheet-avatar-img {
  width: 100%;
  height: 100%;
}

.sheet-item-name {
  flex: 1;
  font-size: 30rpx;
  color: #222;
  margin-left: 24rpx;
}

.sheet-check {
  font-size: 36rpx;
  color: #18AEFB;
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 34rpx;
}

.sheet-add {
  margin-top: 8rpx;
}

.sheet-add-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #888;
  flex-shrink: 0;
}
