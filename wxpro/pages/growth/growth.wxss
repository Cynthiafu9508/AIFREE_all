/* ===== 未绑定状态（原有样式） ===== */
.page {
  min-height: 100vh;
}

.unbound-wrap {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(160deg, #c8d8e2 0%, #a8bcc8 60%, #9aaebb 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 25vh);
}

.tip-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 32rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.tip-lines {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.tip-line {
  display: block;
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.7;
  text-align: center;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.tip-arrow {
  width: 64rpx;
  height: 64rpx;
  margin-top: 16rpx;
  align-self: center;
}

.dog-wrap {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-bottom: 32rpx;
}

.dog-img {
  width: 504rpx;
  height: 378rpx;
}

.btn-wrap {
  width: 80%;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.primary-btn {
  height: 88rpx;
  background: #18AEFB;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 174, 251, 0.4);
}

.tab-placeholder {
  height: calc(100rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

/* 添加设备弹窗 */
.add-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.add-modal {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 48rpx 40rpx;
}
.add-modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 24rpx;
}
.add-modal-step {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 16rpx;
}
.add-modal-img {
  width: 100%;
  margin: 8rpx 0 24rpx;
  border-radius: 16rpx;
}
.add-modal-btn {
  width: 100%;
  height: 96rpx;
  background: #18AEFB;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  margin-top: 8rpx;
}

/* ===== 已绑定状态 ===== */
.bound-page {
  height: 100vh;
  background: #f5f7fa;
  box-sizing: border-box;
}

.bound-header {
  padding: 56rpx 40rpx 32rpx;
  margin-top: 5vh;
}

.bound-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.bound-subtitle {
  display: block;
  font-size: 28rpx;
  color: #888;
  line-height: 1.6;
}

.feature-list {
  padding: 0 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  border-radius: 28rpx;
  border: 3rpx solid transparent;
  overflow: hidden;
  padding: 24rpx;
  box-sizing: border-box;
  gap: 24rpx;
}

.card-active {
  border-width: 3rpx;
  border-style: solid;
}

.feature-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: rgba(255,255,255,0.4);
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 180rpx;
}

.feature-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

.feature-btn-wrap {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.feature-btn {
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0 28rpx;
}

.btn-active {
  background: transparent;
  border: 2rpx solid;
}

.btn-start {
  color: #ffffff;
}
