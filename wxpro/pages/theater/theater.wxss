.page {
  min-height: 100vh;
}

/* ===== 未绑定状态 ===== */
.unbound-wrap {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(160deg, #c8d8e2 0%, #a8bcc8 60%, #9aaebb 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 25vh);
}

.tip-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 32rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.tip-lines {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.tip-line {
  display: block;
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.7;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
}

.tip-arrow {
  width: 64rpx;
  height: 64rpx;
  margin-top: 16rpx;
}

.dog-wrap {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-bottom: 32rpx;
}

.dog-img {
  width: 504rpx;
  height: 378rpx;
}

.btn-wrap {
  width: 80%;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.primary-btn {
  height: 88rpx;
  background: #18AEFB;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(24,174,251,0.4);
}

.tab-placeholder {
  height: calc(100rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.add-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.add-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 48rpx 40rpx;
}
.add-modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 24rpx;
}
.add-modal-step {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 16rpx;
}
.add-modal-img {
  width: 100%;
  margin: 8rpx 0 24rpx;
  border-radius: 16rpx;
}
.add-modal-btn {
  width: 100%;
  height: 96rpx;
  background: #18AEFB;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-top: 8rpx;
}

/* ===== 已绑定状态 ===== */
.bound-page {
  height: 100vh;
  background: #18AEFB;
  box-sizing: border-box;
}

/* Header */
.theater-header {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  padding: 24rpx 32rpx 28rpx;
}

.header-text {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.6;
  max-width: 380rpx;
}

.header-dog {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: -26rpx;
  margin-right: 50rpx;
  flex-shrink: 0;
}

/* Episode list */
.ep-list {
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ep-card {
  background: #ffffff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx;
  gap: 20rpx;
  box-sizing: border-box;
}

/* Thumbnail */
.ep-thumb-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  overflow: hidden;
}

.ep-thumb {
  width: 100%;
  height: 100%;
}

.ep-play-icon {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-triangle {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 20rpx 0 20rpx 36rpx;
  border-color: transparent transparent transparent #ffffff;
  margin-left: 8rpx;
}

.ep-lock-icon {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

/* Episode info */
.ep-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.ep-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
}

.ep-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* Progress row */
.ep-progress-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 4rpx;
}

.ep-progress-label {
  font-size: 22rpx;
  color: #888;
  white-space: nowrap;
  flex-shrink: 0;
}

.ep-progress-bg {
  flex: 1;
  height: 12rpx;
  background: #e8e8e8;
  border-radius: 6rpx;
  overflow: hidden;
}

.ep-progress-fill {
  height: 100%;
  background: #18AEFB;
  border-radius: 6rpx;
}

.ep-progress-num {
  font-size: 22rpx;
  color: #18AEFB;
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
}

/* Status text */
.ep-status-text {
  display: block;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.status-unlocked {
  color: #18AEFB;
}

.status-locked {
  color: #aaa;
}

/* Footer */
.ep-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx 0 20rpx;
}

.ep-footer-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255,255,255,0.4);
}

.ep-footer-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  white-space: nowrap;
}

/* Locked modal */
.locked-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.locked-modal {
  width: 560rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.locked-modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
}

.locked-modal-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
  text-align: center;
}

.locked-modal-btn {
  width: 100%;
  height: 88rpx;
  background: #18AEFB;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-top: 8rpx;
}
