.page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(160deg, #c8d8e2 0%, #a8bcc8 60%, #9aaebb 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 35vh);
}

.tip-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 32rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.tip-lines {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.tip-line {
  display: block;
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.7;
  text-align: center;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.tip-arrow {
  width: 64rpx;
  height: 64rpx;
  margin-top: 16rpx;
  align-self: center;
}

.dog-wrap {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-bottom: 32rpx;
}

.dog-img {
  width: 504rpx;
  height: 378rpx;
}

.btn-wrap {
  width: 80%;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.primary-btn {
  height: 88rpx;
  background: #18AEFB;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 174, 251, 0.4);
}

.tab-placeholder {
  height: calc(100rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
