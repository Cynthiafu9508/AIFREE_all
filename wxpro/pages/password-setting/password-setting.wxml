<view class="page">
  <!-- 状态栏占位，高度由 JS 动态注入 -->
  <view style="height: {{statusBarHeight}}px;"></view>
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">‹</view>
    <text class="nav-title">密码设置</text>
    <view class="nav-right"></view>
  </view>

  <view class="content">
    <text class="page-title">设置密码</text>
    <text class="page-subtitle">用于密码登录</text>

    <!-- 新密码 -->
    <view class="input-wrap">
      <input class="input" placeholder="请输入新密码" placeholder-class="input-placeholder"
        password="{{!showPwd1}}" value="{{pwd1}}" bindinput="onPwd1Input" maxlength="20" />
      <view class="eye-btn" bindtap="togglePwd1">
        <text class="eye-icon">{{showPwd1 ? '👁' : '👁'}}</text>
      </view>
    </view>

    <!-- 确认密码 -->
    <view class="input-wrap">
      <input class="input" placeholder="再次确认新密码" placeholder-class="input-placeholder"
        password="{{!showPwd2}}" value="{{pwd2}}" bindinput="onPwd2Input" maxlength="20" />
      <view class="eye-btn" bindtap="togglePwd2">
        <text class="eye-icon">{{showPwd2 ? '👁' : '👁'}}</text>
      </view>
    </view>

    <view class="btn-confirm" bindtap="onConfirm">确 认</view>
  </view>
</view>
