.page {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  height: 88rpx;
}

.nav-back {
  font-size: 56rpx;
  color: #333;
  width: 64rpx;
  line-height: 1;
  margin-top: -8rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #222;
}

.nav-right { width: 64rpx; }

.content {
  padding: 48rpx 48rpx 0;
  padding-top: calc(10vh + 48rpx);
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.input-wrap {
  width: 100%;
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  height: 96rpx;
}

.input-placeholder { color: #bbb; }

.eye-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-icon { font-size: 36rpx; }

.btn-confirm {
  width: 100%;
  height: 96rpx;
  background: #18AEFB;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 4rpx;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(24,174,251,0.35);
}
