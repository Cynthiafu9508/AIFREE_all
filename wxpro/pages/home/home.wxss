/* ========================
   伙伴页  home.wxss
   间距系统：16 / 24 / 32rpx
   ======================== */

/* ── 页面容器 ── */
.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #c8d8e2 0%, #a8bcc8 60%, #9aaebb 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding-top: env(safe-area-inset-top);
  /* 顶部留白：状态栏以下，内容从约 15% 处开始 */
  padding-top: calc(env(safe-area-inset-top) + 35vh);
}

/* ── ① 提示文案区 ── */
.tip-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 32rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

/* 两行文案容器：两行之间左对齐，整体由 tip-box 居中 */
.tip-lines {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

/* 每一行单独一个 text，不依赖宽度自动换行 */
.tip-line {
  display: block;
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.7;
  text-align: center;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

/* 装饰箭头，视觉引导用，允许自由摆放 */
.tip-arrow {
  width: 64rpx;
  height: 64rpx;
  margin-top: 16rpx;
  align-self: center;
}

/* ── ② 狗狗图片区 ── */
.dog-wrap {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-bottom: 32rpx;
}

.dog-img {
  width: 504rpx;
  height: 378rpx;
}

/* ── ③ 按钮区 ── */
.btn-wrap {
  width: 100%;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.primary-btn {
  height: 88rpx;
  background: #18AEFB;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 174, 251, 0.4);
}

/* ── ④ TabBar 占位 ── */
.tab-placeholder {
  height: calc(100rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
