.page {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  height: 88rpx;
}

.nav-back {
  font-size: 56rpx;
  color: #333;
  width: 64rpx;
  line-height: 1;
  margin-top: -8rpx;
}

.nav-right { width: 64rpx; }

.content {
  flex: 1;
  padding: 32rpx 40rpx 0;
  display: flex;
  flex-direction: column;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 12rpx;
}

.page-sub {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
}

/* 设备名确认行 */
.device-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 40rpx;
}

.device-row-name {
  font-size: 30rpx;
  color: #222;
}

.device-row-check {
  font-size: 36rpx;
  color: #ffffff;
  background: #4caf50;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 52rpx;
}

/* WiFi 信息 */
.section-label {
  display: block;
  font-size: 28rpx;
  color: #555;
  margin-bottom: 20rpx;
}

.input-row {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 28rpx;
  height: 96rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #222;
  height: 96rpx;
}

.input-ph { color: #bbb; }

.select-link {
  font-size: 28rpx;
  color: #18AEFB;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.eye-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.eye-icon { font-size: 34rpx; }

/* 开始配网按钮 */
.btn-start {
  width: 100%;
  height: 96rpx;
  background: #18AEFB;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  margin-top: 48rpx;
  box-sizing: border-box;
}

.btn-start.disabled {
  background: #a0d8fd;
}

/* 选择网络弹窗 */
.picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.picker-card {
  width: 560rpx;
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
}

.picker-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
  text-align: center;
  padding: 40rpx 0 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.picker-item {
  padding: 32rpx 48rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-item-name {
  font-size: 30rpx;
  color: #222;
}
